@model GraysonGains.Models.Entities.Users

<h1>Edit Profile</h1>

<form method="post" asp-action="EditProfileDB" asp-controller="Profile">
    <div class="mt-3">
        <label class="form-label">First Name</label>
        <input type="text" class="form-control" asp-for="FirstName" required />
    </div>
    <div class="mt-3">
        <label class="form-label">Last Name</label>
        <input type="text" class="form-control" asp-for="LastName" required />
    </div>
    <div class="mt-3">
        <label class="form-label">Username</label>
        <input type="text" class="form-control" asp-for="Username" required />
    </div>
    <div class="mt-3">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" asp-for="Email" required />
    </div>
    <div class="mt-3">
        <label class="form-label">Gender</label>
        <div>
            <input type="radio" id="male" asp-for="Gender" value="Male" required />
            <label for="male">Male</label>
            <input type="radio" id="female" asp-for="Gender" value="Female" required />
            <label for="female">Female</label>
        </div>
    </div>
    <div class="mt-3">
        <label class="form-label" for="Heightft">Height</label>
        <div class="d-flex align-items-center">
            <select class="form-control me-2" style="width: auto;" asp-for="HeightFeet" required>
                @for (int i = 3; i <= 7; i++)
                {
                    <option value="@i">@i</option>
                }
            </select>
            <span class="me-2">ft</span>
            <select class="form-control me-2" style="width: auto;" asp-for="HeightInches" required>
                @for (int i = 1; i <= 11; i++)
                {
                    <option value="@i">@i</option>
                }
            </select>
            <span>in</span>
        </div>
    </div>
    <div class="mt-3">
        <label class="form-label">Weight (lbs)</label>
        <input type="number" class="form-control" asp-for="Weight" required />
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary" onclick="saveSuccess()">Save Changes</button>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-danger" onclick="return confirmDeletion()" asp-action="DeleteProfileDB" asp-controller="Profile">Delete Account</button>
    </div>
    <a asp-action="ChangePassword" asp-controller="Profile">Want to change your password? Click here!</a>
</form>

<script>
    const saveSuccess = () => alert("Successfully saved changes.");

    const confirmDeletion = () => confirm("Are you sure you want to delete your account?");
</script>
